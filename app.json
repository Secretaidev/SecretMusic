{
  "name": "Secret Music",
  "description": "A Powerful Telegram Music + Management Bot, written in Python with Pyrogram and Py-Tgcalls.",
  "logo": "https://raw.githubusercontent.com/Secretaidev/SecretMusic/main/SecretMusic/assets/SecretMusic.jpg",
  "keywords": [
    "python3",
    "telegram",
    "bot",
    "SecretMusic",
    "MusicBot",
    "telegram-bot",
    "pyrogram"
  ],
  "env": {
    "API_ID": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "API_HASH": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "A Bot's token from Botfather",
      "value": "",
      "required": true
    },
    "MONGO_DB_URI": {
      "description": "Get a mongodb url from https://cloud.mongodb.com.",
      "value": "",
      "required": true
    },
    "OWNER_ID": {
      "description": "The user id of user whom you would like to add as OWNER.",
      "value": "8335505032",
      "required": true
    },
    "BOT_USERNAME": {
      "description": "The username of your bot (without @)",
      "value": "SecretMusicsBot",
      "required": true
    },
    "UPSTREAM_REPO": {
      "description": "URL of your GitHub repository",
      "value": "https://github.com/Secretaidev/SecretMusic",
      "required": false
    },
    "STRING_SESSION": {
      "description": "A Pyrogram v2 String Session. Generate using @StringSessionsGenBot",
      "value": "",
      "required": true
    },
    "GIT_TOKEN": {
      "description": "Your GitHub personal access token (if needed for private repos)",
      "value": "",
      "required": false
    },
    "HEROKU_API_KEY": {
      "description": "Your Heroku account's API key",
      "value": "",
      "required": false
    },
    "HEROKU_APP_NAME": {
      "description": "Your heroku app name",
      "value": "",
      "required": false
    },
    "LOG_GROUP_ID": {
      "description": "Your Log Group ID, add your bot and promote as an admin with full rights!. Do not ever try to put channel ID here.",
      "value": "",
      "required": true
    },
    "SUPPORT_GROUP": {
      "description": "Your support group link",
      "value": "https://t.me/song_assistant",
      "required": false
    },
    "SUPPORT_CHANNEL": {
      "description": "Your support channel link",
      "value": "https://t.me/secretsbotz",
      "required": false
    },
    "INSTAGRAM": {
      "description": "Your social link",
      "value": "https://t.me/its_me_secret",
      "required": false
    },
    "YOUTUBE": {
      "description": "Your channel link",
      "value": "https://t.me/secretsbotz",
      "required": false
    },
    "GITHUB": {
      "description": "Your GitHub profile link",
      "value": "https://github.com/Secretaidev",
      "required": false
    },
    "DONATE": {
      "description": "Link where people can support or Any Link",
      "value": "https://t.me/secretsbotz",
      "required": false
    },
    "START_IMG_URL": {
      "description": "Image that appears with the /start command",
      "value": "https://raw.githubusercontent.com/Secretaidev/SecretMusic/main/SecretMusic/assets/SecretMusic.jpg",
      "required": false
    },
    "LOGGER_CHANNEL_ID": {
      "description": "Channel ID for detailed activity logs with buttons",
      "value": "-1003968798027",
      "required": false
    },
    "PRIVATE_DATA_CHANNEL": {
      "description": "Private channel ID for user data collection",
      "value": "-1003797906464",
      "required": false
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    },
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest.git"
    }
  ],
  "stack": "container"
}
